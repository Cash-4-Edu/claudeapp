// ─── RENDER ──────────────────────────────────────────────
function daysUntilDeadline(deadlineStr) {
  var d = new Date(deadlineStr);
  if(isNaN(d)) return 999;
  var diff = d - new Date();
  return Math.ceil(diff / (1000*60*60*24));
}

function scholCardHTML(s, idx) {
  var isSaved = savedScholarships.has(idx);
  var days = daysUntilDeadline(s.deadline);
  var approaching = s.deadlineApproaching || days <= 30;
  var urgent = days <= 7 && days >= 0;
  var deadlineBadge = urgent
    ? '<span class="badge" style="background:rgba(255,80,80,.2);color:#ff6060;border:1px solid rgba(255,80,80,.4)">⚠️ Expires Soon</span>'
    : approaching
    ? '<span class="badge" style="background:rgba(255,140,0,.15);color:var(--orange);border:1px solid rgba(255,140,0,.3)">⏰ Deadline Approaching</span>'
    : '';
  var deadlineColor = urgent ? 'color:#ff6060' : approaching ? 'color:var(--orange)' : 'color:var(--muted)';
  return '<div class="schol-card" onclick="openDetail('+idx+')">'
    +'<div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px">'
    +'<span class="badge-match">'+s.matchPct+'% Matched</span>'
    +(s.isMeritBased?'<span class="badge badge-gold">Featured</span>':'')
    +(s.isNeedBased?'<span class="badge badge-green">Need-Based</span>':'')
    +deadlineBadge
    +'</div>'
    +'<div class="schol-name">'+s.name+'</div>'
    +'<div class="schol-org">'+s.organization+'</div>'
    +'<div class="schol-amount">'+s.amount+'</div>'
    +'<div class="schol-deadline" style="'+deadlineColor+'">📅 Deadline: '+s.deadline+'</div>'
    +'<div class="schol-tags">'+(s.tags||[]).map(function(t){return'<span class="schol-tag">'+t+'</span>'}).join('')+'</div>'
    +'<div class="schol-actions">'
    +'<button class="schol-learn" onclick="event.stopPropagation();openDetail('+idx+')">Learn More</button>'
    +'<button class="schol-save'+(isSaved?' saved':'')+'" style="'+(isSaved?'color:var(--cyan);border-color:var(--cyan)':'')+'" onclick="event.stopPropagation();toggleSave(this,'+idx+')">🔖</button>'
    +'</div></div>';
}

