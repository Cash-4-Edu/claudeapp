function openVideo(idx) {
  currentVideoIdx = idx;
  var v = videoLibrary[idx];
  document.getElementById('vp-title').textContent = v.title;
  document.getElementById('vp-channel').textContent = v.channel;
  document.getElementById('vp-token-badge').style.display = 'none';
  document.getElementById('vp-complete-banner').style.display = 'none';
  document.getElementById('sc-video-player').classList.add('show');

  if(ytPlayer) {
    ytPlayer.loadVideoById(v.id);
    ytPlayer.playVideo();
  } else if(ytAPIReady) {
    createYTPlayer(v.id);
  } else {
    // API not loaded yet — try again shortly
    setTimeout(function(){ openVideo(idx); }, 500);
    return;
  }
}

function createYTPlayer(videoId) {
  if(ytPlayer) { ytPlayer.destroy(); ytPlayer = null; }
  ytPlayer = new YT.Player('yt-player', {
    width: window.innerWidth,
    height: window.innerHeight,
    videoId: videoId,
    playerVars:{autoplay:1, playsinline:1, rel:0, modestbranding:1, controls:1},
    events:{
      onStateChange: function(e) {
        if(e.data === YT.PlayerState.ENDED) onVideoEnded();
      }
    }
  });
}

function onVideoEnded() {
  var idx = currentVideoIdx;
  var v = videoLibrary[idx];
  if(!watchedVideos.has(idx)) {
    watchedVideos.add(idx);
