// ─── NAVIGATION ──────────────────────────────────────────
var noNavScreens = ['sc-splash','sc-signup','sc-signin','sc-otp','sc-p1','sc-p2','sc-p3','sc-p4','sc-p5','sc-p6',];

// Navigation history stack for back button
var navHistory = [];

function go(id) {
  // Track profile step completion when leaving a step screen
  var cur = document.querySelector('.screen.active');
  if (cur) {
    var curId = cur.id;
    var stepMatch = curId.match(/^sc-p(\d+)$/);
    if (stepMatch) profileStepsDone.add(parseInt(stepMatch[1]));
    // Push current screen to history (skip loading/splash)
    if (curId && curId !== 'sc-loading' && curId !== id) {
      navHistory.push(curId);
      if (navHistory.length > 30) navHistory.shift(); // cap size
    }
  }
  document.querySelectorAll('.screen').forEach(function(s){s.classList.remove('active')});
  var el = document.getElementById(id);
  if (el) el.classList.add('active');
  var sc = document.getElementById('scroll-container');
  if (sc) sc.scrollTop = 0;
  var bnav = document.getElementById('bnav');
  if (bnav) bnav.classList.toggle('show', noNavScreens.indexOf(id) === -1);
}

function goBack() {
  // Pop history and go to previous screen
  // Skip duplicates and the current screen
  var cur = document.querySelector('.screen.active');
  var curId = cur ? cur.id : '';
  var prev = null;
  while (navHistory.length > 0) {
    var candidate = navHistory.pop();
    if (candidate !== curId) { prev = candidate; break; }
  }
  if (prev) {
    // Don't push to history when going back
    document.querySelectorAll('.screen').forEach(function(s){s.classList.remove('active')});
    var el = document.getElementById(prev);
    if (el) el.classList.add('active');
    document.getElementById('scroll-container').scrollTop = 0;
    var bnav = document.getElementById('bnav');
    bnav.classList.toggle('show', noNavScreens.indexOf(prev) === -1);
  } else {
    // No history — go home
    go(profileComplete ? 'sc-home-post' : 'sc-home-pre');
  }
}


