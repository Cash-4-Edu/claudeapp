function getFiltered(data, filter, searchVal) {
  var out = data;
  if(filter === 'Saved') {
    out = out.filter(function(s,i){ return savedScholarships.has(data.indexOf(s)); });
  } else if(filter && filter !== 'All') {
    var f = filter.toLowerCase();
    out = out.filter(function(s){
      var all = (s.tags||[]).join(' ').toLowerCase() + ' ' + s.name.toLowerCase() + ' ' + (s.description||'').toLowerCase();
      if(f==='merit') return all.includes('merit');
      if(f==='identity') return all.includes('identity')||all.includes('minority')||all.includes('cultural')||all.includes('hispanic')||all.includes('african')||all.includes('native')||all.includes('lgbtq');
      if(f==='first-gen') return all.includes('first-gen')||all.includes('first gen')||all.includes('generation');
      if(f==='essay') return all.includes('essay');
      return all.includes(f);
    });
  }
  if(searchVal) {
    var q = searchVal.toLowerCase();
    out = out.filter(function(s){ return (s.name+s.organization+(s.tags||[]).join(' ')+(s.description||'')).toLowerCase().includes(q); });
  }
  return out;
}

