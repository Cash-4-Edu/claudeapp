// ─── ENSURE PROFILE ───────────────────────────────────────
async function ensureUserProfile(user) {
  if (!supabase) return;
  var res = await supabase.from('user_profiles').select('id').eq('id', user.id).single();
  if (res.error && res.error.code !== 'PGRST116') return;
  if (!res.data) {
    await supabase.from('user_profiles').insert({
      id: user.id, email: user.email, created_at: new Date().toISOString()
    });
  }
}

// ─── ROUTE AFTER AUTH ─────────────────────────────────────
function routeAfterAuth() {
  var dest = profileComplete ? 'sc-home-post' : (savedProfileStep || 'sc-home-pre');
  go(dest);
  var bnav = document.getElementById('bnav');
  if (bnav) bnav.classList.add('show');
  var bnh = document.getElementById('bn-home');
  if (bnh) bnh.classList.add('on');
}

// ─── AUTH ─────────────────────────────────────────────────
async function handleSignUp() {
  var email = '', password = '', firstName = '', lastName = '';
  document.querySelectorAll('#sc-signup input').forEach(function(inp) {
    if (inp.type === 'email') email = inp.value.trim();
    else if (inp.type === 'password') password = inp.value;
    else if ((inp.placeholder||'').toLowerCase().includes('first') || inp.id === 'firstName') firstName = inp.value.trim();
    else if ((inp.placeholder||'').toLowerCase().includes('last')) lastName = inp.value.trim();
  });
  if (!email)            { showToast('Enter your email'); return; }
  if (!password)         { showToast('Enter a password'); return; }
  if (password.length<6) { showToast('Password needs 6+ characters'); return; }
  var name = firstName || email.split('@')[0];
  showToast('Creating account...');
  try {
    var r = await supabase.auth.signUp({ email: email, password: password,
      options: { data: { first_name: name, last_name: lastName } } });
    if (r.error) throw r.error;
    if (r.data.session) {
      updateUserName(name);
      await ensureUserProfile(r.data.user);
      showToast('Welcome, ' + name + '!');
      routeAfterAuth();
    } else {
      var r2 = await supabase.auth.signInWithPassword({ email: email, password: password });
      if (r2.error) throw r2.error;
      updateUserName(name);
      await ensureUserProfile(r2.data.user);
      showToast('Welcome back!');
      routeAfterAuth();
    }
  } catch(err) { showToast(err.message || 'Something went wrong'); }
}

async function handleSignIn() {
  var email    = (document.querySelector('#sc-signin input[type="email"]')||{value:''}).value.trim();
  var password = (document.querySelector('#sc-signin input[type="password"]')||{value:''}).value;
  if (!email)    { showToast('Please enter your email'); return; }
  if (!password) { showToast('Please enter your password'); return; }
  showToast('Signing in...');
  try {
    var r = await supabase.auth.signInWithPassword({ email: email, password: password });
    if (r.error) throw r.error;
    await ensureUserProfile(r.data.user);
    await loadUserData(r.data.user);
    showToast('Welcome back!');
    routeAfterAuth();
  } catch(err) { showToast(err.message || 'Sign in failed'); }
}

async function signInWithGoogle() {
  try {
    var r = await supabase.auth.signInWithOAuth({ provider: 'google',
      options: { redirectTo: window.location.href.split('#')[0].split('?')[0] } });
    if (r.error) throw r.error;
  } catch(err) { showToast(err.message || 'Google sign-in failed'); }
}

async function signOut() {
  await supabase.auth.signOut();
  profileComplete = false; scholarshipData = [];
  totalTokens = 0; weeklyTokens = 0;
  updateTokenDisplays();
  go('sc-splash');
  var bnav = document.getElementById('bnav');
  if (bnav) bnav.classList.remove('show');
}

// ─── LOAD USER DATA ────────────────────────────────────────
async function loadUserData(user) {
  if (!user || !supabase) return;
  var pr = await supabase.from('profiles').select('*').eq('id', user.id).single();
  if (pr.data) {
    updateUserName(pr.data.first_name || '');
    totalTokens   = pr.data.tokens || 0;
    weeklyTokens  = pr.data.weekly_tokens || 0;
    profileComplete = pr.data.profile_complete || false;
    updateTokenDisplays();
    var pp = document.getElementById('prof-pct-label');
    var pb = document.getElementById('prof-pct-bar');
    if (pp) pp.textContent = (pr.data.profile_pct || 0) + '%';
    if (pb) pb.style.width  = (pr.data.profile_pct || 0) + '%';
    var se = document.getElementById('settings-email');
    if (se) se.textContent = user.email || pr.data.email || '-';
  }
  var sr = await supabase.from('scholarships').select('*').eq('user_id', user.id).order('match_pct', {ascending:false});
  if (sr.data && sr.data.length) {
    scholarshipData = sr.data.map(function(s){ return {
      name:s.name,organization:s.organization,orgName:s.org_name,orgIcon:s.org_icon,
      orgDesc:s.org_desc,amount:s.amount,deadline:s.deadline,
      deadlineApproaching:s.deadline_approaching,description:s.description,
      tags:s.tags||[],matchPct:s.match_pct,applyUrl:s.apply_url,
      isNeedBased:s.is_need_based,isMeritBased:s.is_merit_based,
      benefits:s.benefits||[],eligibility:s.eligibility||[],
      requirements:s.requirements||[],applySteps:s.apply_steps||[],_dbId:s.id
    };});
    renderHomeSchols(); renderScholTab();
    var cnt = document.getElementById('profile-match-count');
    if (cnt) cnt.textContent = scholarshipData.length;
  }
  var vr = await supabase.from('videos_watched').select('video_id').eq('user_id', user.id);
  if (vr.data) vr.data.forEach(function(w){
    var i = videoLibrary.findIndex(function(v){ return v.id === w.video_id; });
    if (i !== -1) watchedVideos.add(i);
  });
  var up = await supabase.from('user_profiles').select('last_step,onboarding_complete').eq('id', user.id).single();
  if (up.data) {
    savedProfileStep = up.data.last_step || null;
    if (up.data.onboarding_complete) profileComplete = true;
  }
}

// ─── SAVE PROFILE STEP ────────────────────────────────────
async function saveProfileStep(data) {
  if (!supabase) return;
  var u = await supabase.auth.getUser();
  if (!u.data || !u.data.user) { console.warn('No user session'); return; }
  var r = await supabase.from('user_profiles').upsert({
    id: u.data.user.id, updated_at: new Date().toISOString()
  });
  // merge data fields
  var payload = Object.assign({ id: u.data.user.id, updated_at: new Date().toISOString() }, data);
  await supabase.from('user_profiles').upsert(payload);
  console.log('Profile step saved');
}

// ─── SAVE FOR LATER ────────────────────────────────────────
async function saveForLater(stepId) {
  var stepNum = parseInt(stepId.replace('sc-p', ''));
  savedProfileStep = stepId;
  await saveProfileStep({ last_step: stepId, progress_step: stepNum });
  var meta = (typeof stepMeta !== 'undefined' && stepMeta[stepId]) || { num: 1, name: 'Personal Info' };
  var lbl = document.getElementById('saved-step-label');
  var nm  = document.getElementById('saved-step-name');
  var ov  = document.getElementById('save-later-overlay');
  if (lbl) lbl.textContent = meta.num;
  if (nm)  nm.textContent  = meta.name;
  if (ov)  ov.classList.add('show');
}

// ─── HIDE LOADER ──────────────────────────────────────────
function hideLoader() {
  var el = document.getElementById('sc-loading');
  if (!el) return;
  el.style.transition = 'opacity .4s ease';
  el.style.opacity = '0';
  setTimeout(function() { el.style.display = 'none'; }, 400);
}

// ─── APP INIT ──────────────────────────────────────────────
function _appInit() {
  if (!supabase && window.supabase) supabase = window.supabase;
  if (_appInit._done) return;
  _appInit._done = true;

  // Show splash behind loader
  var splash = document.getElementById('sc-splash');
  if (splash) splash.classList.add('active');

  if (!supabase) {
    // Supabase CDN didn't load — just show splash
    setTimeout(function() { hideLoader(); startSplashAuto(); }, 2200);
    return;
  }

  // Listen for OAuth redirects
  supabase.auth.onAuthStateChange(function(event, session) {
    if (event === 'SIGNED_IN' && session && session.user) {
      ensureUserProfile(session.user).then(function() {
        return loadUserData(session.user);
      }).then(function() {
        routeAfterAuth();
      });
    }
  });

  setTimeout(async function() {
    hideLoader();
    try {
      var r = await supabase.auth.getSession();
      if (r.data && r.data.session && r.data.session.user) {
        await ensureUserProfile(r.data.session.user);
        await loadUserData(r.data.session.user);
        routeAfterAuth();
      } else {
        startSplashAuto();
      }
    } catch(err) {
      console.error('INIT ERROR:', err);
      startSplashAuto();
    }
    setTimeout(function(){ renderVideoList(); renderPerksGrid(); renderTuitionList(); }, 300);
  }, 2200);
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', _appInit);
} else {
  _appInit();
}
ent.addEventListener('DOMContentLoaded', _appInit);
} else {
  _appInit();
}
</script>


