<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>CASH4EDU</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden}
body{background:#111;display:flex;justify-content:center;align-items:flex-start;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:#e8f0ff}

:root{
  --bg:#080f1e;--card:#0d1a2e;
  --cyan:#00d4ff;--blue:#1a6aff;--green:#00e676;
  --orange:#ff8c00;--gold:#ffd700;
  --text:#e8f0ff;--muted:#6a7a9a;
  --border:rgba(255,255,255,0.08);
}

.phone{width:100%;max-width:430px;height:100vh;background:var(--bg);display:flex;flex-direction:column;overflow:hidden}

.scroll-container{flex:1;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch;padding-bottom:70px}
.scroll-container::-webkit-scrollbar{display:none}

/* ── FIXED BOTTOM NAV ── */
.bnav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;height:64px;background:#0a1220;border-top:1px solid var(--border);display:none;align-items:center;z-index:100}
.bnav.show{display:flex}
.bni{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;cursor:pointer;padding:8px 0;opacity:.4;color:var(--muted);transition:opacity .2s}
.bni.on{opacity:1;color:var(--cyan)}
.bni-ico{font-size:20px;line-height:1}
.bni-lbl{font-size:10px;font-weight:600}

/* ── SCREENS ── */
.screen{display:none;flex-direction:column;min-height:calc(100vh - 64px);animation:fadeIn .25s ease}
.screen.active{display:flex}
@keyframes fadeIn{from{opacity:0;transform:translateX(18px)}to{opacity:1;transform:translateX(0)}}

/* ── SHARED ── */
.btn{width:100%;padding:15px;border-radius:14px;font-size:15px;font-weight:700;cursor:pointer;border:none;font-family:inherit}
.btn-cyan{background:linear-gradient(135deg,var(--cyan),var(--blue));color:#fff}
.btn-outline{background:transparent;color:var(--cyan);border:1.5px solid rgba(0,212,255,.35)}
.btn-dark{background:rgba(255,255,255,.07);color:var(--text)}
.inp{width:100%;padding:13px 15px;background:rgba(255,255,255,.05);border:1.5px solid var(--border);border-radius:12px;color:var(--text);font-size:15px;font-family:inherit;outline:none}
.inp:focus{border-color:var(--cyan)}
.inp::placeholder{color:var(--muted)}
select.inp{background:#0d1a2e;appearance:none}
.lbl{display:block;font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:7px}
.fld{margin-bottom:14px}
.fld-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.chips{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:4px}
.chip{padding:8px 14px;border-radius:20px;cursor:pointer;border:1.5px solid var(--border);background:rgba(255,255,255,.04);color:var(--text);font-size:13px;font-weight:500;font-family:inherit;transition:all .15s}
.chip.on{border-color:var(--cyan);background:rgba(0,212,255,.12);color:var(--cyan)}
.ri{display:flex;align-items:center;gap:12px;padding:12px 14px;background:rgba(255,255,255,.04);border:1.5px solid var(--border);border-radius:12px;cursor:pointer;margin-bottom:8px}
.ri.on{border-color:var(--cyan);background:rgba(0,212,255,.07)}
.rdot{width:18px;height:18px;border-radius:50%;flex-shrink:0;border:2px solid var(--muted);display:flex;align-items:center;justify-content:center}
.ri.on .rdot{border-color:var(--cyan)}
.rdot-in{width:8px;height:8px;border-radius:50%;background:var(--cyan);display:none}
.ri.on .rdot-in{display:block}
.trow{display:flex;align-items:center;justify-content:space-between;padding:13px 0;border-bottom:1px solid var(--border)}
.tgl{width:44px;height:26px;border-radius:13px;position:relative;cursor:pointer;border:none;flex-shrink:0;background:rgba(255,255,255,.15)}
.tgl.on{background:var(--cyan)}
.tgl::after{content:'';position:absolute;top:3px;left:3px;width:20px;height:20px;background:#fff;border-radius:50%;transition:transform .2s}
.tgl.on::after{transform:translateX(18px)}
.tag{display:inline-block;background:rgba(0,212,255,.12);color:var(--cyan);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;padding:4px 10px;border-radius:20px;margin-bottom:10px}
.ibox{background:rgba(0,212,255,.08);border:1px solid rgba(0,212,255,.2);border-radius:12px;padding:12px 14px;font-size:12px;color:rgba(255,255,255,.7);line-height:1.5;margin-bottom:16px;display:flex;gap:10px;align-items:flex-start}
.ubox{border:2px dashed rgba(0,212,255,.3);border-radius:14px;padding:16px;text-align:center;margin-bottom:12px}
.ubtn{padding:7px 14px;border-radius:8px;border:1px solid var(--cyan);background:transparent;color:var(--cyan);font-size:12px;cursor:pointer;font-family:inherit}
.hdr{padding:52px 28px 12px;display:flex;align-items:center;gap:12px;flex-shrink:0}
.back{width:36px;height:36px;border-radius:10px;background:rgba(255,255,255,.07);border:none;color:var(--text);font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.bot{padding:12px 28px 32px;flex-shrink:0}
.h1{font-size:28px;font-weight:900;line-height:1.1;margin-bottom:6px}
.sub{font-size:13px;color:var(--muted);margin-bottom:20px}
.hint{font-size:12px;color:var(--muted);text-align:center;margin-top:12px}
.hint span{color:var(--cyan);cursor:pointer}
.stepbar{padding:0 28px 14px;display:flex;align-items:center;gap:10px;flex-shrink:0}
.strk{flex:1;height:4px;background:rgba(255,255,255,.1);border-radius:2px;overflow:hidden}
.sfil{height:100%;background:linear-gradient(90deg,var(--cyan),var(--blue));border-radius:2px;transition:width .4s}
.slbl{font-size:11px;color:var(--muted);white-space:nowrap}
.sbtn{width:100%;padding:13px;border-radius:12px;background:rgba(255,255,255,.06);border:1px solid var(--border);color:var(--text);font-size:14px;font-weight:600;cursor:pointer;margin-bottom:10px;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:10px}
.dvdr{display:flex;align-items:center;gap:10px;margin:14px 0;color:var(--muted);font-size:12px}
.dvdr-l{flex:1;height:1px;background:var(--border)}
.otp-row{display:flex;gap:8px;justify-content:center;margin:24px 0}
.otp-box{width:46px;height:58px;border-radius:12px;background:rgba(255,255,255,.06);border:2px solid var(--border);text-align:center;font-size:24px;font-weight:700;color:var(--text);outline:none;font-family:inherit}
.otp-box:focus{border-color:var(--cyan)}
.select-note{font-size:11px;color:var(--cyan);margin-bottom:8px;font-style:italic}
.other-inp{margin-top:8px;display:none}
.other-inp.show{display:block}

/* ── BADGES ── */
.badge{padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700;white-space:nowrap}
.badge-green{background:rgba(0,230,118,.15);color:var(--green);border:1px solid rgba(0,230,118,.3)}
.badge-blue{background:rgba(26,106,255,.2);color:#4d8fff}
.badge-gold{background:rgba(255,215,0,.15);color:var(--gold);border:1px solid rgba(255,215,0,.3)}
.badge-match{background:rgba(0,230,118,.15);color:var(--green);border:1px solid rgba(0,230,118,.3);padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700}

/* ── LOADING SCREEN ── */
.loading-screen{position:fixed;inset:0;background:var(--bg);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;width:100%;}
.loading-logo-box{width:80px;height:80px;border-radius:24px;background:linear-gradient(135deg,var(--cyan),var(--blue));display:flex;align-items:center;justify-content:center;margin-bottom:20px;box-shadow:0 0 40px rgba(0,212,255,.4)}
.loading-logo-text{font-size:14px;font-weight:900;color:#fff;letter-spacing:1px}
.loading-title{font-size:26px;font-weight:900;color:var(--cyan);margin-bottom:8px;letter-spacing:1px}
.loading-sub{font-size:13px;color:var(--muted);margin-bottom:40px}
.loading-bar-wrap{width:200px;height:4px;background:rgba(255,255,255,.1);border-radius:2px;overflow:hidden}
.loading-bar-fill{height:100%;background:linear-gradient(90deg,var(--cyan),var(--blue));border-radius:2px;animation:loadProg 2.2s ease forwards}
@keyframes loadProg{from{width:0}to{width:100%}}
.loading-dots{display:flex;gap:6px;justify-content:center;margin-top:28px}
.loading-dot{width:8px;height:8px;border-radius:50%;background:rgba(0,212,255,.3);animation:dotPulse 1.2s ease infinite}
.loading-dot:nth-child(2){animation-delay:.2s}
.loading-dot:nth-child(3){animation-delay:.4s}
@keyframes dotPulse{0%,100%{background:rgba(0,212,255,.3)}50%{background:var(--cyan)}}

/* ── ONBOARDING SPLASH ── */
.splash-slide{position:absolute;inset:0;display:flex;flex-direction:column;opacity:0;transition:opacity .6s ease;pointer-events:none}
.splash-slide.active{opacity:1;pointer-events:all}
.splash-bg{position:absolute;inset:0;background-size:cover;background-position:center}
.splash-overlay{position:absolute;inset:0;background:linear-gradient(to bottom, rgba(8,15,30,0.2) 0%, rgba(8,15,30,0.55) 45%, rgba(8,15,30,0.97) 100%)}
.splash-content{position:relative;z-index:2;display:flex;flex-direction:column;height:100%;padding:0 28px 44px}
.splash-logo-row{display:flex;align-items:center;gap:10px;padding-top:56px}
.splash-logo-box{width:40px;height:40px;border-radius:12px;background:linear-gradient(135deg,var(--cyan),var(--blue));display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:900;color:#fff;letter-spacing:1px}
.splash-logo-text{font-size:18px;font-weight:900;color:#fff;letter-spacing:1px}
.splash-text-area{margin-top:auto}
.splash-headline{font-size:32px;font-weight:900;line-height:1.1;margin-bottom:12px;color:#fff}
.splash-desc{font-size:15px;color:rgba(255,255,255,.8);line-height:1.6;margin-bottom:28px}
.splash-controls{display:flex;align-items:center;justify-content:space-between}
.splash-skip{font-size:14px;color:rgba(255,255,255,.6);cursor:pointer;background:none;border:none;font-family:inherit}
.splash-next{width:56px;height:56px;border-radius:50%;background:var(--cyan);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(0,212,255,.4)}
.splash-next svg{width:22px;height:22px;fill:#fff}
.splash-dots-row{display:flex;gap:6px;align-items:center}
.splash-dot{width:6px;height:6px;border-radius:3px;background:rgba(255,255,255,.3);transition:all .3s}
.splash-dot.on{width:20px;background:#fff}

/* ── ONBOARDING WRAPPER ── */
.onboard-wrap{position:relative;width:100%;height:100vh;overflow:hidden;background:var(--bg)}

/* ── HOME ── */
.topbar{padding:48px 20px 12px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.token-pill{background:rgba(255,200,0,.12);border:1px solid rgba(255,200,0,.3);border-radius:20px;padding:6px 12px;display:flex;align-items:center;gap:6px;font-size:13px;font-weight:700;color:var(--gold)}
.notif-btn{width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,.07);border:none;color:var(--text);font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center}
.welcome-card{margin:0 16px 14px;background:linear-gradient(135deg,#0d2040,#0a1830);border:1px solid rgba(0,212,255,.15);border-radius:18px;padding:18px}
.journey-row{display:flex;align-items:center;gap:12px;background:rgba(0,212,255,.08);border:1px solid rgba(0,212,255,.15);border-radius:12px;padding:12px;margin:12px 0}
.j-icon{width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,var(--cyan),var(--blue));display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.pbar{height:6px;background:rgba(255,255,255,.1);border-radius:3px;margin:10px 0 6px;overflow:hidden}
.pfil{height:100%;background:linear-gradient(90deg,var(--cyan),var(--blue));border-radius:3px;transition:width .6s ease}
.section-hdr{display:flex;align-items:center;justify-content:space-between;padding:0 16px;margin-bottom:10px}
.section-title{font-size:16px;font-weight:800;display:flex;align-items:center;gap:6px}
.section-link{font-size:12px;color:var(--cyan);cursor:pointer}
.banner-strip{margin:0 16px 14px;background:linear-gradient(135deg,rgba(26,106,255,.2),rgba(0,212,255,.1));border:1px solid rgba(0,212,255,.2);border-radius:14px;padding:14px 16px;font-size:13px;cursor:pointer;display:flex;align-items:center;gap:8px}
.streak-card{margin:0 16px 14px;background:linear-gradient(135deg,#0d1f3a,#0a1530);border:1px solid rgba(0,212,255,.15);border-radius:18px;padding:16px}
.search-row{margin:0 16px 10px;position:relative}
.search-inp{width:100%;padding:12px 16px;background:rgba(255,255,255,.06);border:1px solid var(--border);border-radius:12px;color:var(--text);font-size:14px;font-family:inherit;outline:none}
.search-inp::placeholder{color:var(--muted)}
.filter-scroll{display:flex;gap:8px;padding:0 16px;margin-bottom:14px;overflow-x:auto}
.filter-scroll::-webkit-scrollbar{display:none}
.filter-chip{flex-shrink:0;padding:6px 14px;border-radius:20px;border:1px solid var(--border);background:rgba(255,255,255,.05);color:var(--text);font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s}
.filter-chip.on{background:rgba(0,212,255,.12);border-color:var(--cyan);color:var(--cyan)}

/* ── SCHOLARSHIP CARD ── */
.schol-card{margin:0 16px 14px;background:var(--card);border:1px solid var(--border);border-radius:16px;padding:16px;cursor:pointer;transition:border-color .15s,transform .15s}
.schol-card:active{transform:scale(.98);border-color:rgba(0,212,255,.3)}
.schol-name{font-size:15px;font-weight:800;margin-bottom:3px;line-height:1.3}
.schol-org{font-size:12px;color:var(--muted);margin-bottom:8px}
.schol-amount{font-size:20px;font-weight:900;color:var(--green);margin-bottom:3px}
.schol-deadline{font-size:12px;color:var(--muted);margin-bottom:10px}
.schol-tags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px}
.schol-tag{padding:4px 10px;border-radius:20px;font-size:11px;background:rgba(255,255,255,.07);color:var(--muted)}
.schol-actions{display:flex;gap:10px;align-items:center}
.schol-learn{flex:1;padding:10px;border-radius:10px;border:1.5px solid var(--cyan);background:transparent;color:var(--cyan);font-size:13px;font-weight:700;cursor:pointer;font-family:inherit}
.schol-save{padding:10px 14px;border-radius:10px;border:1.5px solid var(--border);background:transparent;color:var(--muted);font-size:18px;cursor:pointer;transition:all .2s}
.schol-save.saved{border-color:var(--cyan);color:var(--cyan)}
.schol-loading{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48px 28px;text-align:center;gap:16px}
.spin{width:48px;height:48px;border-radius:50%;border:3px solid rgba(0,212,255,.2);border-top-color:var(--cyan);animation:spin 1s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── VIDEO / PERK ── */
.video-scroll{display:flex;gap:12px;padding:0 16px;overflow-x:auto;margin-bottom:14px}
.video-scroll::-webkit-scrollbar{display:none}
.vid-card{flex-shrink:0;width:160px;background:var(--card);border-radius:14px;overflow:hidden;cursor:pointer}
.vid-thumb{height:90px;background:linear-gradient(135deg,#1a2a40,#0d3050);position:relative;display:flex;align-items:center;justify-content:center;font-size:28px}
.vid-badge{position:absolute;top:8px;right:8px;background:var(--blue);color:#fff;font-size:10px;font-weight:700;padding:3px 7px;border-radius:10px}
.vid-dur{position:absolute;bottom:6px;left:8px;font-size:10px;color:rgba(255,255,255,.7);background:rgba(0,0,0,.5);padding:2px 6px;border-radius:6px}
.vid-info{padding:10px}
.vid-title{font-size:12px;font-weight:700;line-height:1.3;margin-bottom:6px}
.vid-meta{display:flex;align-items:center;justify-content:space-between}
.vid-level{font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px}
.level-beg{background:rgba(0,230,118,.15);color:var(--green)}
.level-int{background:rgba(255,140,0,.15);color:var(--orange)}
.perk-scroll{display:flex;gap:12px;padding:0 16px;overflow-x:auto;margin-bottom:14px}
.perk-scroll::-webkit-scrollbar{display:none}
.perk-card{flex-shrink:0;width:160px;background:var(--card);border-radius:14px;overflow:hidden;position:relative}
.perk-locked{position:absolute;inset:0;background:rgba(8,15,30,.75);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:6px;font-size:11px;color:var(--muted);border-radius:14px}
.perk-img{height:80px;display:flex;align-items:center;justify-content:center;font-size:36px;background:linear-gradient(135deg,#1a0f0f,#2a1010)}
.perk-info{padding:10px}
.perk-name{font-size:12px;font-weight:700;margin-bottom:4px}
.perk-desc{font-size:10px;color:var(--muted);line-height:1.3}
.perk-token-cost{font-size:11px;font-weight:700;color:var(--gold);margin-bottom:6px}
.perk-learn{width:100%;padding:7px;background:rgba(0,212,255,.1);border:1px solid rgba(0,212,255,.3);border-radius:8px;color:var(--cyan);font-size:11px;font-weight:700;cursor:pointer;font-family:inherit;margin-top:4px}
.pc-card{margin:0 16px 14px;background:var(--card);border:1px solid var(--border);border-radius:16px;padding:16px}
.check-row{display:flex;align-items:center;gap:10px;margin:8px 0;font-size:13px}
.check-ico{width:20px;height:20px;border-radius:50%;background:rgba(0,212,255,.15);border:1.5px solid var(--cyan);display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0}

/* ── DETAIL SCREEN ── */
.detail-screen{position:fixed;inset:0;background:var(--bg);z-index:200;display:none;flex-direction:column;width:100%;max-width:430px;left:50%;transform:translateX(-50%);right:auto}
.detail-screen.show{display:flex;animation:slideUp .3s ease}
@keyframes slideUp{from{opacity:0;transform:translateX(-50%) translateY(30px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
.detail-hdr{padding:48px 20px 14px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;border-bottom:1px solid var(--border)}
.detail-body{flex:1;overflow-y:auto;padding:0 0 100px}
.detail-body::-webkit-scrollbar{display:none}
.detail-foot{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;padding:12px 20px 32px;background:var(--bg);border-top:1px solid var(--border);display:flex;flex-direction:column;gap:10px;z-index:10;right:auto}

.det-hero{padding:20px 20px 16px;background:linear-gradient(160deg,#0d2040,#080f1e)}
.det-badges{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px;align-items:center}
.det-title{font-size:22px;font-weight:900;line-height:1.2;margin-bottom:16px}
.det-amounts{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px}
.det-amount-box{background:rgba(255,255,255,.06);border:1px solid var(--border);border-radius:14px;padding:14px}
.det-amount-val{font-size:22px;font-weight:900;color:var(--green)}
.det-amount-lbl{font-size:11px;color:var(--muted);margin-top:2px}
.det-deadline-val{font-size:17px;font-weight:800;color:var(--text)}
.det-tags{display:flex;gap:6px;flex-wrap:wrap}
.det-tag{padding:5px 10px;border-radius:20px;font-size:11px;font-weight:600;background:rgba(255,255,255,.07);color:var(--muted);display:flex;align-items:center;gap:4px}
.det-section{padding:20px 20px 0}
.det-section-title{font-size:17px;font-weight:800;margin-bottom:12px}
.det-about-text{font-size:14px;color:rgba(255,255,255,.75);line-height:1.7}
.det-benefits-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.det-benefit{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px;text-align:center}
.det-benefit-ico{font-size:28px;margin-bottom:8px}
.det-benefit-name{font-size:13px;font-weight:700;margin-bottom:4px}
.det-benefit-desc{font-size:11px;color:var(--muted);line-height:1.4}
.det-eligibility-list{display:flex;flex-direction:column;gap:10px}
.det-elig-item{display:flex;gap:10px;align-items:flex-start;font-size:14px;line-height:1.5}
.det-elig-key{color:var(--cyan);font-weight:700;white-space:nowrap}
.det-req-list{display:flex;flex-direction:column;gap:10px}
.det-req-item{display:flex;align-items:center;gap:12px;background:var(--card);border:1px solid var(--border);border-radius:12px;padding:13px 14px}
