function buildPrompt(p) {
  var today = new Date().toISOString().split('T')[0];
  return 'You are a scholarship verification advisor for CASH4EDU. Today is '+today+'. Generate exactly 8 REAL, currently accepting applications US scholarships that ACTUALLY EXIST and are CURRENTLY OPEN or opening soon in 2025-2026.\n\nCRITICAL RULES:\n- Every scholarship MUST be real and verifiable at its URL\n- Deadlines must be accurate and in the future (after '+today+')\n- Requirements, GPA minimums, eligibility must be factually correct\n- applyUrl must be the real, working application page\n- Set deadlineApproaching:true if deadline is within 30 days of '+today+'\n- Do NOT invent scholarships or fabricate details\n\nStudent Profile:\n- Education: '+(p.educationLevel||'Undergraduate')+'\n- Major: '+(p.major||'General')+'\n- GPA: '+(p.gpa||'Not specified')+'\n- State: '+(p.state||'Not specified')+'\n- Race/Ethnicity: '+(p.race||'Not specified')+'\n- Gender: '+(p.gender||'Not specified')+'\n- First-Gen: '+(p.firstGen||'Unknown')+'\n- Income: '+(p.income||'Not specified')+'\n- College Type: '+(p.collegeType||'Any')+'\n- Heritage: '+(p.heritage||'None')+'\n- Scholarship Types: '+(p.scholTypes||'Any')+'\n\nReturn ONLY a valid JSON array. Structure:\n[{"name":"exact official scholarship name","organization":"exact org name","orgName":"display name","orgIcon":"emoji","orgDesc":"one sentence mission","amount":"exact award amount","deadline":"Month DD, YYYY","deadlineApproaching":false,"description":"2-3 accurate sentences","tags":["tag1","tag2"],"matchPct":87,"applyUrl":"https://exact-real-url.org","isNeedBased":true,"isMeritBased":false,"benefits":[{"icon":"💰","name":"name","desc":"desc"}],"eligibility":[{"key":"Label","val":"exact requirement"}],"requirements":[{"icon":"📝","name":"name","desc":"desc"}],"applySteps":["step1","step2","step3","step4"]}]\n\nExactly 4 benefits, 4 eligibility, 4 requirements, 4 steps per scholarship. Return ONLY the JSON array, no markdown.';
}

async function fetchScholarships() {
  // If Supabase is connected, use the Edge Function (keeps API key secure)
  if (supabase) {
    try {
      var session = await supabase.auth.getSession();
      var token = session.data && session.data.session && session.data.session.access_token;
      if (token) {
        var efRes = await fetch('https://ufqnbkzjvcuvouwdmlgr.supabase.co/functions/v1/match-scholarships', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token, 'apikey': 'sb_publishable_iDiITnRLTSAqYWM3OyJysQ_Gwq08L7g' },
          body: JSON.stringify({})
        });
        var efData = await efRes.json();
        if (efData.scholarships && efData.scholarships.length) {
          scholarshipData = efData.scholarships;
          renderMatches(); renderHomeSchols(); renderScholTab();
          var cnt = document.getElementById('profile-match-count');
          if (cnt) cnt.textContent = scholarshipData.length;
          return;
        }
      }
    } catch(efErr) { console.warn('Edge function error, falling back:', efErr); }
  }
  // Fallback: call Claude API directly (demo mode)
  try {
    var res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        model: 'claude-sonnet-4-5-20251001',
        max_tokens: 4096,
        messages: [{role: 'user', content: buildPrompt(userProfile)}]
      })
    });
    if (!res.ok) throw new Error('API ' + res.status);
    var data = await res.json();
    var raw = (data.content && data.content[0] ? data.content[0].text : '');
    // Aggressively extract JSON array only
    raw = raw.replace(/```json/gi,'').replace(/```/g,'');
    var s = raw.indexOf('['), e = raw.lastIndexOf(']');
    if (s === -1 || e === -1 || e <= s) throw new Error('No JSON array in response');
    raw = raw.slice(s, e + 1);
    // Remove ALL control chars except whitespace
    raw = raw.replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F]/g, '');
    // Fix common Claude JSON issues: trailing commas before }
    raw = raw.replace(/,(\s*[}\]])/g, '$1');
    scholarshipData = JSON.parse(raw);
    if (!Array.isArray(scholarshipData) || !scholarshipData.length) throw new Error('Empty');
    renderMatches(); renderHomeSchols(); renderScholTab();
    var cnt = document.getElementById('profile-match-count');
    if (cnt) cnt.textContent = scholarshipData.length;
  } catch(err) {
    console.error('Scholarship fetch error:', err);
    scholarshipData = fallbackSchols();
    renderMatches(); renderHomeSchols(); renderScholTab();
    var cnt = document.getElementById('profile-match-count');
    if (cnt) cnt.textContent = scholarshipData.length;
  }
}

