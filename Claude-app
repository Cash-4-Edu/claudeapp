function earnTokens(amount, source) {
  // Profile-completion tokens only when all 6 steps done
  if (source === 'profile_complete' && profileStepsDone.size < 6) return;
  totalTokens += amount;
  weeklyTokens += amount;
  updateTokenDisplays();
  // Persist to Supabase
  if (supabase && amount > 0) {
    supabase.auth.getUser().then(function(r){
      if (r.data && r.data.user) {
        supabase.rpc('award_tokens', {
          p_user_id: r.data.user.id,
          p_amount: amount,
          p_reason: source || 'app_action'
        }).catch(function(e){ console.warn('Token sync error:', e); });
      }
    });
  }
}

function updateTokenDisplays() {
  var ids = ['post-token-count','schol-token-count','perks-token-count','profile-token-count','pre-token-count','profile-tokens-display'];
  ids.forEach(function(id){
    var el = document.getElementById(id);
    if(el) el.textContent = totalTokens;
  });
  var wt = document.getElementById('weekly-tokens');
  if(wt) wt.textContent = weeklyTokens;
}

